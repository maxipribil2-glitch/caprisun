// ════════════════════════════════════════════════════════════════
//  Illegalo + Illegalo Gamecenter — Firestore Security Rules
//  (seit dem Merge läuft das Gamecenter über DIESES Projekt,
//  illegalo-shopzone — kein eigenes Firebase-Projekt mehr nötig)
// ════════════════════════════════════════════════════════════════
//
//  ✅ UPDATE: Illegalo (admin/dev/lieferant) hat jetzt ECHTES Firebase
//  Auth (Email/Passwort im Hintergrund, gleicher Trick wie beim
//  Gamecenter — username@illegalo.local). request.auth.uid ist für
//  diese drei Seiten jetzt eine echte, geprüfte Identität, keine reine
//  Behauptung mehr. Heißt: orders.update/delete, customerNotes,
//  auditLog, blockedUsers, lieferantAvailability, siteStatus und
//  gcConfig dürfen jetzt NUR von eingeloggtem Illegalo-Personal
//  geschrieben werden (Helper-Funktion isIllegaloStaff(), prüft die
//  @illegalo.local-Email-Domain), nicht mehr von jedem Internet-Bot
//  mit dem API-Key — und auch nicht von Gamecenter-Spielern, die sich
//  den gleichen Auth-Pool teilen, aber eine andere Email-Domain haben.
//
//  Shop selbst (shop.html) hat weiterhin KEIN Login — Bestellungen
//  aufgeben bleibt bewusst offen für alle (Freundeskreis-Modell), nur
//  Ändern/Löschen einer Bestellung braucht jetzt echten Admin/
//  Lieferant-Login. presence, errorLog und meta/orderCounter bleiben
//  ebenfalls offen, weil die auch von Shop-Besuchern ohne Login
//  geschrieben werden (Live-Tracking, Fehler-Logging, Bestellnummer).
//
//  Granularere Rollen (z.B. "nur Lieferant darf eigene Verfügbarkeit
//  ändern", "nur Dev darf User sperren") würden eine zusätzliche
//  staffRoles-Lookup-Collection brauchen (UID → Rolle) — aktuell reicht
//  "ist überhaupt eingeloggtes Illegalo-Personal" als Stufe. Sag
//  Bescheid falls du die feinere Trennung willst.
//
//  Das Gamecenter hat ebenfalls echtes Firebase Auth für seine Spieler
//  (gc-index.html) — request.auth.uid greift dort genauso, deshalb sind
//  users/invites/rooms/scores unten echt zugriffsbeschränkt (nur eigene
//  Daten lesen/schreiben). Der Kill-Switch (gcConfig/site) braucht jetzt
//  ebenfalls echten Illegalo-Login zum Schreiben (siehe oben), Lesen
//  bleibt offen, weil gc-index.html ihn auch ohne Login anzeigen muss.
//  Online-Status läuft separat über Realtime Database (siehe
//  database.rules.json) — Firestore Rules hier betreffen das nicht.
//
//  Was diese Rules bringen:
//  ✅ Nur die hier gelisteten Collections sind überhaupt erreichbar —
//     alles andere ist automatisch zu (Firestore deny-by-default für
//     nicht gematchte Pfade).
//  ✅ Jedes Dokument muss eine plausible Form haben (richtige Felder,
//     richtige Typen, sinnvolle Längen-/Größen-Limits).
//  ✅ auditLog ist komplett unveränderlich (nur create, nie update/delete).
//  ✅ Schreibender Zugriff auf interne Collections braucht jetzt echten,
//     geprüften Illegalo-Login statt nur den (eh öffentlichen) API-Key.
//
//  DEPLOY:
//  Firebase Console → Projekt illegalo-shopzone → Firestore Database
//  → Regeln → Inhalt hier einfügen → "Veröffentlichen".
// ════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Illegalo-Personal UND Gamecenter-Spieler teilen sich jetzt den gleichen
    // Firebase-Auth-Pool (ein Projekt für beides). request.auth != null allein
    // würde also auch JEDEN eingeloggten Gamecenter-Spieler durchlassen — das
    // reicht für sensible Illegalo-Sachen (Kill-Switch, Sperren, Audit-Log etc.)
    // nicht. Deshalb zusätzlich die Email-Domain checken: Illegalo-Personal hat
    // immer @illegalo.local, Gamecenter-Spieler immer @mpgames.local.
    // MAP FEATURE (Verbesserungsvorschlag Punkt 2): zusätzlich zur Email-Domain
    // jetzt auch ne explizite UID-Allowlist — BEIDE Bedingungen müssen zutreffen.
    // Verhindert dass ein aus Versehen angelegter @illegalo.local-Account (Tippfehler
    // bei Registrierung) automatisch Staff-Rechte bekommt. Liste manuell pflegen,
    // gleiche UIDs wie in Supabase's staff_uids-Tabelle.
    function isIllegaloStaff() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email.matches('.*@illegalo[.]local$')
          && request.auth.uid in [
            'PbwdFCaIndWuVq4btXwMCZPwxxg2', // giannihay
            'iLbijuqyS0OiO9wXtCDKg7eNpTg1', // philippstangl
            'DLrzZ4Kbq0Si1Tz8fmsrFARxuMy2', // henrikstelzner
            'kI069Fob1SUxn4pto2boADLsZF73'  // maxipribil (Owner)
          ];
    }

    // MAP FEATURE: Kill Switch server-seitig durchsetzen — der Screen selbst
    // (HTML/CSS/JS) kann NIE 100% umgehungssicher gemacht werden, wer DevTools
    // offen hat kann jedes Element löschen/verstecken. ABER: diese Funktion
    // sorgt dafür dass selbst bei umgangenem Screen NIX FUNKTIONIERT — jeder
    // kritische Write wird hier server-seitig blockiert, unabhängig davon was
    // im Browser sichtbar/versteckt is. Macht den Bypass rein kosmetisch/nutzlos.
    // isIllegaloStaff() darf den Kill Switch selbst umgehen (braucht Zugriff
    // aufs Dev Panel um ihn ja überhaupt wieder auszuschalten!).
    function killSwitchActive() {
      return !isIllegaloStaff()
          && exists(/databases/$(database)/documents/siteStatus/main)
          && get(/databases/$(database)/documents/siteStatus/main).data.reason == 'killswitch';
    }

    // ── orders ──────────────────────────────────────────────
    // Shop ist bewusst öffentlich (jeder sieht alle Bestellungen,
    // Freundeskreis-Modell) → read bleibt offen.
    // Gruppenbestellungen: mehrere Leute sammeln Items zu einer gemeinsamen Lieferung,
    // bevor einer von ihnen die fertige Sammel-Order ganz normal in "orders" postet.
    // Offen wie der Rest vom Shop (kein Login nötig) — Freundeskreis-Modell, der
    // 6-stellige Zufallscode ist der einzige Zugangsschutz (wie ein Spielraum-Code).
    match /groupOrders/{code} {
      allow read: if true;
      allow create: if !killSwitchActive()
                    && request.resource.data.items is list
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.status is string;
      allow update: if !killSwitchActive()
                    && request.resource.data.items is list
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.status is string;
      allow delete: if true;
    }

    match /orders/{orderId} {
      allow read: if true;

      allow create: if !killSwitchActive()
                    && request.resource.data.keys().hasAll(
                        ['customer','items','total','status','cat','pay','ship','date']
                      )
                    && request.resource.data.customer is map
                    && request.resource.data.customer.name is string
                    && request.resource.data.customer.name.size() > 0
                    && request.resource.data.customer.name.size() < 120
                    && request.resource.data.customer.address is string
                    && request.resource.data.customer.address.size() > 0
                    && request.resource.data.customer.address.size() < 300
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.total < 100000
                    && request.resource.data.status is string
                    && request.resource.data.cat is string
                    && request.resource.data.pay is string
                    && request.resource.data.ship is string;

      // Update: Status/Zuweisung/Artikel/Notiz/Verlauf dürfen geändert
      // werden, aber die Grundform muss weiter stimmen (kein Wegmurksen
      // von Pflichtfeldern, keine absurden Werte). Jetzt zusätzlich:
      // nur eingeloggtes Admin/Lieferant-Personal (Shop selbst ändert nie eigene Orders).
      allow update: if isIllegaloStaff()
                    && request.resource.data.customer is map
                    && request.resource.data.customer.name is string
                    && request.resource.data.items is list
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.total < 100000
                    && request.resource.data.status is string
                    // orderNumber darf sich nie ändern, sonst sind
                    // Tracking-Links/CSV-Exports im Chaos
                    && request.resource.data.orderNumber == resource.data.orderNumber;

      // Löschen geht jetzt nur noch mit echtem Illegalo-Login (Admin Panel).
      allow delete: if isIllegaloStaff();
    }

    // ── meta/orderCounter ───────────────────────────────────
    // Fortlaufende Bestellnummer via Transaction.
    match /meta/orderCounter {
      allow read: if true;
      allow write: if request.resource.data.value is int
                   && request.resource.data.value >= 0
                   && request.resource.data.value < 1000000;
    }

    // ── presence (Live-User-Tracking) ───────────────────────
    match /presence/{sessionId} {
      allow read: if true;
      // Löschen passiert nur von admin.html (eigener Logout) und dev.html
      // (Stale-Purge) — beide jetzt mit echtem Login. Shop selbst löscht nie.
      allow delete: if isIllegaloStaff();
      // Create bleibt offen — auch Shop-Besucher ohne Login schreiben hier.
      allow create: if request.resource.data.page in ['shop','admin','lieferant']
                    && request.resource.data.user is string
                    && request.resource.data.user.size() < 60
                    && request.resource.data.device is string
                    && request.resource.data.device.size() < 80;
      // MAP FEATURE (Verbesserungsvorschlag Punkt 3): Update bekommt jetzt ein
      // serverseitiges Mindest-Intervall (15s) zwischen zwei Schreibvorgängen
      // auf DIESELBE Session — der normale Client-Heartbeat läuft alle 20s und
      // bleibt davon unberührt, aber Spam über direkte API-Calls (Browser-
      // Konsole, außerhalb der App) wird jetzt serverseitig blockiert.
      allow update: if request.resource.data.page in ['shop','admin','lieferant']
                    && request.resource.data.user is string
                    && request.resource.data.user.size() < 60
                    && request.resource.data.device is string
                    && request.resource.data.device.size() < 80
                    && (!('lastSeen' in resource.data)
                        || request.time > resource.data.lastSeen + duration.value(15, 's'));
    }

    // ── customerNotes (Admin-Notizen pro Kunde) ─────────────
    match /customerNotes/{noteId} {
      allow read: if true;
      allow write: if isIllegaloStaff()
                   && request.resource.data.name is string
                   && request.resource.data.note is string
                   && request.resource.data.note.size() < 2000
                   && request.resource.data.updatedBy is string;
    }

    // ── auditLog (Lösch-Protokoll — UNVERÄNDERLICH) ─────────
    match /auditLog/{entryId} {
      allow read: if true;
      allow create: if isIllegaloStaff()
                    && request.resource.data.action is string
                    && request.resource.data.by is string
                    && request.resource.data.at is string;
      allow update, delete: if false; // echtes Audit-Log: niemand darf's nachträglich anfassen
    }

    // ── errorLog (automatisches JS-Error-Logging) ───────────
    match /errorLog/{entryId} {
      allow read: if true;
      allow delete: if true; // Dev Panel "Alle Logs löschen"
      allow create: if request.resource.data.page is string
                    && request.resource.data.message is string
                    && request.resource.data.message.size() < 2000;
      allow update: if false;
    }

    // ── blockedUsers (Login-Sperren aus dem Dev Panel) ──────
    match /blockedUsers/{username} {
      allow read: if true;
      allow write: if isIllegaloStaff() && request.resource.data.blocked is bool;
    }

    // ── lieferantAvailability (Verfügbarkeits-Toggle) ───────
    match /lieferantAvailability/{lieferant} {
      allow read: if true;
      allow write: if isIllegaloStaff() && request.resource.data.available is bool;
    }

    // ── siteStatus/main (Maintenance-Schalter + Zeitplan) ───
    match /siteStatus/main {
      allow read: if true;
      allow write: if isIllegaloStaff()
                   && (!('home' in request.resource.data) || request.resource.data.home is bool)
                   && (!('shop' in request.resource.data) || request.resource.data.shop is bool)
                   && (!('admin' in request.resource.data) || request.resource.data.admin is bool)
                   && (!('lieferant' in request.resource.data) || request.resource.data.lieferant is bool)
                   && (!('scheduleEnabled' in request.resource.data) || request.resource.data.scheduleEnabled is bool)
                   && (!('expressPrice' in request.resource.data)
                       || (request.resource.data.expressPrice is number
                           && request.resource.data.expressPrice >= 0
                           && request.resource.data.expressPrice <= 20))
                   && (!('supportEmail' in request.resource.data)
                       || (request.resource.data.supportEmail is string
                           && request.resource.data.supportEmail.size() < 100))
                   && (!('reason' in request.resource.data)
                       || request.resource.data.reason == null
                       || request.resource.data.reason in ['ferien','krank','geschlossen','mittagspause','killswitch']);
    }

    // ════════════════════════════════════════════════════════
    //  🎮 ILLEGALO GAMECENTER — läuft über das gleiche Projekt
    //  (illegalo-shopzone), seit dem Merge kein eigenes Firebase-
    //  Projekt mehr. Zwei Welten treffen hier aufeinander:
    //  - users/invites/rooms/scores: echte Spieler-Accounts mit
    //    echtem Firebase Auth (request.auth existiert wirklich) —
    //    hier GEHT echte Zugriffskontrolle, und wird auch genutzt.
    //  - gcConfig/site (Kill-Switch): Lesen bleibt offen (gc-index.html
    //    muss ihn auch ohne Login anzeigen), Schreiben braucht jetzt
    //    isIllegaloStaff() — sonst könnte jeder eingeloggte Gamecenter-
    //    Spieler den Kill-Switch selbst umlegen, weil sich Illegalo-
    //    Personal und Spieler den gleichen Auth-Pool teilen.
    //    Online-Status (wer ist online) läuft separat über Realtime
    //    Database, nicht über Firestore — siehe database.rules.json.
    // ════════════════════════════════════════════════════════

    match /gcConfig/site {
      allow read: if true;
      allow write: if isIllegaloStaff()
                   && (!('maintenance' in request.resource.data) || request.resource.data.maintenance is bool);
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false);
      // MAP FIX (Coin-System-Bug!): vorher stand hier
      //   request.resource.data.isAdmin == resource.data.isAdmin
      // — das WIRFT in Firestore-Rules einen Fehler wenn das Feld in einem der
      // beiden Docs gar nicht existiert (Gamecenter-Accounts haben kein isAdmin!),
      // und ein Fehler in Rules = DENY. Ergebnis: JEDES updateDoc auf users/{uid}
      // wurde abgelehnt -> keine Coins, kein Daily Bonus, gar nix. Jetzt mit
      // .get(field, default), das failt nie:
      allow update: if request.auth != null && request.auth.uid == uid &&
        request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false);
    }

    match /invites/{inviteId} {
      allow create: if !killSwitchActive() && request.auth != null && request.auth.uid == request.resource.data.from;
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow update: if !killSwitchActive() && request.auth != null &&
        (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    match /rooms/{roomId} {
      allow create: if !killSwitchActive() && request.auth != null && request.auth.uid in request.resource.data.players;
      // MAP FIX: vorher durfte NUR gelesen werden wer selbst Spieler war — das
      // hat das "Live-Zuschauer"-Feature in lobby.js (listenLiveMatches/
      // listenActiveRooms, zeigt bewusst FREMDE aktive Matches an) komplett
      // blockiert, weil Firestore Collection-Queries ablehnt sobald die Regel
      // nicht für JEDEN möglichen Treffer ohne extra Filter verifizierbar ist.
      allow read: if request.auth != null;
      allow update: if !killSwitchActive() && request.auth != null && request.auth.uid in resource.data.players;
    }

    // arcade high-score leaderboard (snake — solo, async bragging rights)
    // Lieblingsgegner-Liste pro Spieler — nur der eigene Account darf seine Liste lesen/schreiben
    match /gcFavorites/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if !killSwitchActive() && request.auth != null && request.auth.uid == uid;
    }

    match /scores/{scoreId} {
      allow read: if request.auth != null;
      allow create: if !killSwitchActive()
        && request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.game in ['snake', 'breakout', '2048', 'flappy', 'minesweeper', 'memory', 'stacktower', 'anagramm', 'coinrush', 'wordle', 'simon', 'typing', 'sudoku', 'pixelart', 'slithersolo', 'wham', 'bubbleshooter', 'stroop', 'balloonpop', 'wordsearch', 'trivia']
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score < 100000;
      allow update, delete: if false; // append-only leaderboard, niemand kann nachträglich fälschen
    }

    // append-only Match-Ergebnis-Log, Basis für die Bilanz-Seite (stats.html)
    match /matchResults/{id} {
      allow read: if request.auth != null;
      allow create: if !killSwitchActive()
        && request.auth != null
        && request.auth.uid in request.resource.data.players
        && request.resource.data.game in ['tictactoe','snakeio','katapult','connect4','pong','reaction','battleship','nim','quiz','chess','airhockey','bomberman','artillery','rps','checkers','guesswho','pool','towerdefense','wordchain','mancala','uno'];
      allow update, delete: if false;
    }

    // Turnier-Räume
    match /tournaments/{tid} {
      allow read: if request.auth != null;
      allow create: if !killSwitchActive() && request.auth != null && request.resource.data.host == request.auth.uid;
      allow update: if !killSwitchActive() && request.auth != null;
    }

    // Roulette shared table
    match /rouletteTables/{tableId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }

    // MAP FEATURE (Verbesserungsvorschlag Punkt 1): eigene Log-Collection für
    // Voucher-Einlösungen — läuft NICHT über auditLog, weil das isIllegaloStaff()
    // braucht und normale Gamecenter-Accounts (die den Voucher einlösen) das
    // nicht erfüllen. Jeder darf nur EIGENE Einträge schreiben, lesen dürfen alle
    // eingeloggten (Staff kann so nachvollziehen wer wann was eingelöst hat).
    match /voucherLog/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    // Alles andere: automatisch zu (kein Wildcard-Match = deny by default)
  }
}
